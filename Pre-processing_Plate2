##Pre-processing raw Plate2 reads
##Trim-galore script with fastqc

##Navigate to your directory

cd /mnt/colston/microworkshop/asherc/

##Activate the trim-galore conda environment

conda activate trim-galore2

##Run trim galore

trim_galore -q 20 --fastqc -o trimmed_plate2_reads /mnt/colston/microworkshop/data/raw_data/plate2_pre-trimmed_raw_fastq_files/*.fastq.gz
    #run in screen: screen -S preposs

##After script is finished, clean up output

screen -r preposs #check to ensure it finished
exit 
cd trimmed_plate2_reads/

mkdir trimmed_fastqc_results

mv *fastqc* trimmed_fastqc_results/
