#We can see reads dip down at like 240, and that’s the same value used in the tutorial, so we can keep that for our DADA2:

#This step takes a while so if you want, you can run it as a screen by doing the following:

screen -S DADA2
conda activate qiime2-amplicon-2026.1

qiime dada2 denoise-single \
--i-demultiplexed-seqs 16S_demux_seqs.qza \
--p-trim-left 0 \
--p-trunc-len 240 \
--o-representative-sequences 16S_asv-seqs.qza \
--o-table 16S_asv-table.qza \
--o-denoising-stats 16S_denoising-stats.qza \
--o-base-transition-stats base-transition-stats.qza

#To exit the screen (detach):
Ctrl + A, then D

#To return to a screen:
screen -r DADA2

exit #To kill/terminate screen

#Next we need a database 

cp /mnt/colston/microworkshop/data/qiime2_input/SILVA138.2_SSURef_NR99_uniform_classifier_V4-515f-806r.qza /mnt/colston/microworkshop/asherc/post_filtering/16S/

qiime feature-classifier classify-sklearn \
--i-classifier SILVA138.2_SSURef_NR99_uniform_classifier_V4-515f-806r.qza \
--i-reads 16S_asv-seqs.qza \
--o-classification 16S_taxonomy.qza
	
#output: 16S_taxonomy.qza

qiime phylogeny align-to-tree-mafft-fasttree \
--i-sequences 16S_asv-seqs.qza \
--o-alignment 16S_asv-seqs.qza \
--o-masked-alignment masked-aliigned_16S_asv-seqs.qza \
--o-tree unrooted-tree_16S.qza \
--o-rooted-tree rooted-tree_16S.qza

qiime feature-table summarize \
--i-table 16S_asv-table.qza \
--m-metadata-file 16S_Metadata.txt \
--o-feature-frequencies feature-frequencies.qza \
--o-sample-frequencies sample-frequencies.qza \
--o-summary 16S_asv-table.qzv
#output: 16S_asv-table.qzv

#If you visualize the last .qzv generated, and select the middle tab (interactive sample detail), then scroll down, you can see the lowest freq. As you can see the lowest is 872, so let’s purge lowest by setting the cutoff to 4440 for this data (example from workshop)

#For the 16S I decided to make the cutoff 12000 so the next command looks like:

qiime diversity core-metrics-phylogenetic \
--i-phylogeny rooted-tree_16S.qza \
--i-table 16S_asv-table.qza \
--p-sampling-depth 12000 \
--m-metadata-file 16S_Metadata.txt \
--output-dir diversity-core-metrics-phylogenetic

qiime diversity alpha-group-significance \
--i-alpha-diversity diversity-core-metrics-phylogenetic/shannon_vector.qza \
--m-metadata-file 16S_Metadata.txt \
--o-visualization shannon_group_significance.qzv

#output: Saved Visualization to: shannon_group_significance.qzv

#Beta group significance (Sample_Type Comparison): Unweighted- and Weighted-Unifrac
qiime diversity beta-group-significance \
--i-distance-matrix diversity-core-metrics-phylogenetic/unweighted_unifrac_distance_matrix.qza \
--m-metadata-file 16S_Metadata.txt \
--m-metadata-column Sample_Type \
--p-pairwise \
--o-visualization unweighted_sample_type_group_sig.qzv

#output: Saved Visualization to: unweighted_sample_type_group_sig.qzv

